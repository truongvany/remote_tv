<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Deep Sea Blue to Vibrant Purple Gradient -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="108"
                android:type="linear">
                <item android:color="#00E5FF" android:offset="0.0" />  <!-- Xanh Ngọc / Lục lam -->
                <item android:color="#2563EB" android:offset="0.5" />  <!-- Xanh Nước Biển -->
                <item android:color="#9333EA" android:offset="1.0" />  <!-- Tím Sáng -->
            </gradient>
        </aapt:attr>
    </path>
    
    <!-- Soft overlay reflection for 3D look / depth -->
    <path android:pathData="M 0,0 L 108,0 L 108,40 C 70,60 30,30 0,60 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0" android:startY="0"
                android:endX="108" android:endY="60"
                android:type="linear">
                <item android:color="#4DFFFFFF" android:offset="0" />
                <item android:color="#00FFFFFF" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle dark vignette at the bottom right -->
    <path android:pathData="M108,108m-108,0a108,108 0 1,1 216,0a108,108 0 1,1 -216,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="108" android:centerY="108"
                android:gradientRadius="108"
                android:type="radial">
                <item android:color="#4D000000" android:offset="0" />
                <item android:color="#00000000" android:offset="1" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
